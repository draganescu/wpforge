# Cerebras inference (OpenAI-compatible endpoint)
# Get a key at https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Optional overrides (sensible defaults baked in)
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# Default model is zai-glm-4.7 (best coder available on most Cerebras accounts).
# Model availability depends on your account — list yours with:
#   curl -H "Authorization: Bearer $CEREBRAS_API_KEY" https://api.cerebras.ai/v1/models
# CEREBRAS_MODEL=zai-glm-4.7
# WPFORGE_CONCURRENCY=6
